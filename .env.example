# ─── Copy to .env and fill in. ───
# Every exchange key is optional: without keys an exchange is still listed and
# connectable by UID, but cashback accrual stays off for it. The Mini App, the
# demo data and the public showcase work regardless.

# --- Core ---
ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-random-string

# --- Postgres ---
POSTGRES_DB=cashback
POSTGRES_USER=cashback
POSTGRES_PASSWORD=change-me-strong-random

# --- Connections (defaults target docker compose service names) ---
DATABASE_URL=postgresql+asyncpg://cashback:change-me-strong-random@postgres:5432/cashback
REDIS_URL=redis://redis:6379/0

# --- Telegram ---
# Bot token from @BotFather. Required for real Mini App auth and the bot;
# leave empty to run the public showcase / demo only.
TG_BOT_TOKEN=
# Bot username without @ — used to build referral links.
TG_BOT_USERNAME=your_cashback_bot
# Public domain the Mini App is served from (CORS + bot WebApp button).
WEB_DOMAIN=localhost:8080

# --- Mini App (build-time) ---
# Origin of the API the browser calls (also allowed by the nginx CSP).
VITE_API_BASE=http://localhost:8000

# --- Demo ---
# true → showcase endpoints fall back to demo data while the DB is thin.
DEMO_SOCIAL_PROOF=true

# --- BingX (Broker / Affiliate) ---
BINGX_API_KEY=
BINGX_API_SECRET=
BINGX_DEFAULT_REFERRAL_URL=

# --- Binance (apiReferral, email-based) ---
BINANCE_API_KEY=
BINANCE_API_SECRET=
# Our share of the referral's fee (e.g. 0.40). 0 → Binance accrual off.
BINANCE_REBATE_RATE=0
BINANCE_DEFAULT_REFERRAL_URL=

# --- Bitget (Agent, UID-based, needs passphrase) ---
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=
BITGET_REBATE_RATE=0
BITGET_DEFAULT_REFERRAL_URL=

# --- MEXC (Affiliate, UID-based) ---
MEXC_API_KEY=
MEXC_API_SECRET=
MEXC_REBATE_RATE=0
MEXC_DEFAULT_REFERRAL_URL=

# --- BYDFi (Affiliate, UID-based; base must end with /api) ---
BYDFI_API_KEY=
BYDFI_API_SECRET=
BYDFI_BASE_URL=https://api.bydfi.com/api
BYDFI_REBATE_RATE=0
BYDFI_DEFAULT_REFERRAL_URL=

# --- Withdrawals ---
WITHDRAWAL_MIN_USD=1
WITHDRAWAL_DAILY_LIMIT_USD=5000
WITHDRAWAL_MONTHLY_LIMIT_USD=20000
WITHDRAWAL_COOLDOWN_MINUTES=30
